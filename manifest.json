{
  "manifest_version": 3,
  "name": "Search URL in Google",
  "version": "1.0",
  "description": "Adds a 'Search in Google' context menu entry for selected URLs.",
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
